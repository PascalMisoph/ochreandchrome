---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GuideCard from "../../components/GuideCard.astro";
import NewsletterSignup from "../../components/NewsletterSignup.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { guideCategories, guides } from "../../data/site";

const featured = guides[0];
---

<BaseLayout
  title="Guides for the Intentional Home | Ochre & Chrome"
  description="Styling rules, material notes, and room-by-room interior design direction from Ochre & Chrome."
>
  <main class="editorial-page guides-page">
    <section class="oc-hero oc-hero--dark guides-hub-hero">
      <img src="/ochre-assets/guides-hub-hero-exact.png" alt="" class="oc-hero__image" />
      <div class="oc-hero__shade"></div>
      <SiteHeader current="guides" variant="overlay" className="guides-hub-nav" />
      <div class="oc-hero__content">
        <p class="oc-kicker">Guides</p>
        <h1>Guides for the Intentional Home</h1>
        <p>Styling rules, material notes, and room-by-room direction.</p>
        <div class="filter-row" aria-label="Guide categories">
          {guideCategories.map((category, index) => (
            <a class={index === 0 ? "is-active" : ""} href="#guide-grid">{category}</a>
          ))}
        </div>
      </div>
    </section>

    <section class="featured-guide">
      <div class="vertical-mark">
        <span>O<br />&amp;<br />C</span>
      </div>
      <div class="featured-guide__copy">
        <p class="oc-kicker">Featured Guide</p>
        <h2>{featured.title}</h2>
        <p>{featured.dek} Learn how to build balance, story, and polish without overdecorating.</p>
        <a href={`/guides/${featured.slug}/`} class="text-link">Explore the Guide</a>
      </div>
      <a href={`/guides/${featured.slug}/`} class="featured-guide__media">
        <img src="/ochre-assets/guides-hub-featured-exact.png" alt="" />
      </a>
    </section>

    <section class="guide-index" id="guide-grid">
      <div class="section-title-line">
        <h2>Guides</h2>
        <span></span>
      </div>
      <div class="guide-index__grid">
        {guides.map((guide) => (
          <GuideCard
            title={guide.title}
            image={guide.image}
            href={`/guides/${guide.slug}/`}
            category={guide.category}
            variant="tile"
          />
        ))}
      </div>
    </section>

    <section class="principles-strip" aria-label="Design principles">
      <p class="oc-kicker">Design Principles</p>
      <div>
        <span>Intentional over impulse</span>
        <span>Materials with integrity</span>
        <span>Balance over symmetry</span>
        <span>Layered with purpose</span>
        <span>Timeless not trendy</span>
      </div>
    </section>

    <section class="newsletter-panel">
      <img src="/ochre-assets/guides-hub-newsletter-exact.png" alt="" />
      <div>
        <h2>Design inspiration, straight to your inbox.</h2>
        <p>New guides, design notes, and curated finds for an intentional home.</p>
        <NewsletterSignup buttonLabel="Coming Soon" />
      </div>
    </section>

  </main>
</BaseLayout>
