---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About | Ochre & Chrome" description="About Ochre & Chrome, an editorial interiors publication for considered living.">
  <main class="legal-page">
    <a href="/" class="oc-brand">Ochre <span>&amp;</span> Chrome</a>
    <p class="oc-kicker">About</p>
    <h1>Curated home. Considered living.</h1>
    <p>
      Ochre & Chrome is an editorial home platform for layered interiors, thoughtful shopping, and
      design guidance with warmth, craft, and restraint.
    </p>
    <p>
      The site focuses on the Neo Deco and Afrohemian worlds: polished geometry, warm materiality,
      collected texture, and design choices that feel intentional rather than disposable.
    </p>
    <p>
      Product notes and guides are written as editorial direction first. Affiliate purchase links
      remain disabled until verified partner destinations are available.
    </p>
  </main>
</BaseLayout>
