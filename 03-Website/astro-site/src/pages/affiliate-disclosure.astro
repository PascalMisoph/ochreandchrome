---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Affiliate Disclosure | Ochre & Chrome"
  description="Affiliate disclosure for Ochre & Chrome product recommendations."
>
  <main class="legal-page">
    <a href="/" class="oc-brand">Ochre <span>&amp;</span> Chrome</a>
    <p class="oc-kicker">Disclosure</p>
    <h1>Affiliate Disclosure</h1>
    <p>
      Ochre & Chrome may earn a commission when readers buy through qualifying partner links at no
      extra cost to the reader. Affiliate links are not active on the site until verified partner
      destinations are added.
    </p>
    <p>
      Product mentions remain editorial. Retailer availability, prices, shipping, and returns are
      controlled by the third-party retailer.
    </p>
  </main>
</BaseLayout>
