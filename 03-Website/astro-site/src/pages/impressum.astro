    <section class="legal-section">
      <h2>Contact</h2>
      <p>
        Email: <a href="mailto:hello@ochreandchrome.com">hello@ochreandchrome.com</a>
      </p>
    </section>

    <section class="legal-section">
      <h2>Responsible for Editorial Content</h2>
      <p>
        Pascal Misoph<br />
        Holbeinstr. 7<br />
