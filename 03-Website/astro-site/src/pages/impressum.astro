---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Impressum | Ochre & Chrome" description="Impressum and contact information for Ochre & Chrome.">
  <main class="legal-page">
    <a href="/" class="oc-brand">Ochre <span>&amp;</span> Chrome</a>
    <p class="oc-kicker">Legal</p>
    <h1>Impressum</h1>
    <p>
      Ochre & Chrome is an editorial interior design publication. Verified contact information
      currently available in this repository: hello@ochreandchrome.com.
    </p>
    <p>
      Legal operator name, postal address, responsible person, business registration, VAT/tax
      details, and jurisdiction-specific disclosures have not been provided in the repository and
      must be supplied by a human owner before launch.
    </p>
  </main>
</BaseLayout>
