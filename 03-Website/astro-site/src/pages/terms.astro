---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
---

<BaseLayout title="Terms | Ochre & Chrome" description="Terms of use for Ochre & Chrome.">
  <main class="editorial-page legal-page legal-page--structured">
    <SiteHeader />

    <section class="legal-hero">
      <p class="oc-kicker">Terms</p>
      <h1>Terms of Use</h1>
      <p>Rules for using the Ochre & Chrome website.</p>
    </section>

    <section class="legal-section">
      <h2>Provider</h2>
      <p>
        Ochre & Chrome is operated by Pascal Misoph, Holbeinstr. 7, 01307 Dresden, Germany.
      </p>
    </section>

    <section class="legal-section">
      <h2>Editorial Content</h2>
      <p>
        Ochre & Chrome publishes editorial interior design guidance, product commentary, and
        inspiration for personal, non-commercial use. Content is provided for general information and
        inspiration only.
      </p>
    </section>

    <section class="legal-section">
      <h2>Products and External Links</h2>
      <p>
        Product recommendations are editorial. Where affiliate or partner links are active, they lead
        to third-party providers whose own terms, prices, delivery rules, privacy policies, and return
        policies apply. Affiliate partner destinations are disabled until verified links are added.
      </p>
    </section>

    <section class="legal-section">
      <h2>No Checkout</h2>
      <p>
        The website does not currently operate checkout, order fulfillment, returns, trade accounts,
        paid subscriptions, or customer accounts.
      </p>
    </section>

    <section class="legal-section">
      <h2>Intellectual Property</h2>
      <p>
        Website content, layout, text, and visual presentation may not be copied, reproduced, or used
        commercially without permission unless statutory exceptions apply.
      </p>
    </section>

    <section class="legal-section">
      <h2>Contact</h2>
      <p>
        For questions about these terms, contact
        <a href="mailto:hello@ochreandchrome.com">hello@ochreandchrome.com</a>.
      </p>
    </section>
  </main>
</BaseLayout>
