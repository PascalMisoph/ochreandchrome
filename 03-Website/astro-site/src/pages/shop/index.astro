---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AffiliateDisclosure from "../../components/AffiliateDisclosure.astro";
import ProductCard from "../../components/ProductCard.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { products } from "../../data/site";

const categories = ["Furniture", "Lighting", "Decor", "Textiles"];
const seenCategories = new Set();
const productGrid = products.map((product) => {
  const isFirstInCategory = !seenCategories.has(product.category);
  seenCategories.add(product.category);

  return {
    product,
    anchorId: isFirstInCategory ? product.category.toLowerCase() : undefined
  };
});
---

<BaseLayout
  title="The Curated Cart | Ochre & Chrome"
  description="Editor-selected affiliate home pieces for intentional rooms."
>
  <main class="editorial-page cart-page">
    <SiteHeader current="shop" />

    <section class="cart-hero">
      <div>
        <h1>The Curated Cart</h1>
        <p class="cart-dek">Editor-selected pieces for intentional rooms.</p>
        <p>
          We source from trusted makers and design partners to help you create a home that feels
          collected, considered, and timeless.
        </p>
      </div>
      <img src="/ochre-assets/curated-cart-hero.png" alt="" />
    </section>

    <nav class="cart-tabs" aria-label="Product categories">
      {categories.map((category) => <a href={`#${category.toLowerCase()}`}>{category}</a>)}
    </nav>

    <section class="featured-collection">
      <div>
        <p class="oc-kicker">Featured Collection</p>
        <h2>Modern Heritage</h2>
        <p>A blend of old-world materials and modern silhouettes. These pieces anchor a room with warmth, texture, and quiet character.</p>
        <a href="/guides/layering-like-a-designer/" class="text-link">Why We Chose It</a>
      </div>
      <img src="/homepage-generated-assets-hires/hero-interior.png" alt="" />
    </section>

    <section class="product-showroom" aria-label="Product grid">
      {productGrid.map(({ product, anchorId }) => (
        <ProductCard product={product} variant="commerce" anchorId={anchorId} />
      ))}
    </section>

    <AffiliateDisclosure />

    <section class="shop-look">
      <div>
        <p class="oc-kicker">Style It Together</p>
        <h2>Shop the Look</h2>
        <p>These pieces come together in our Modern Heritage living room. Explore the full guide for layout tips, finishes, and styling notes.</p>
        <a href="/guides/layering-like-a-designer/" class="button-dark">View the Guide</a>
      </div>
      <img src="/homepage-generated-assets-hires/testimonial-vignette.png" alt="" />
    </section>

  </main>
</BaseLayout>
