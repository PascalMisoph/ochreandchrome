---
import BaseLayout from "../layouts/BaseLayout.astro";

const navItems = [
  { label: "Shop", href: "/shop/" },
  { label: "Guides", href: "/guides/" },
  { label: "Trend Report", href: "/trend-report/" },
  { label: "About", href: "/about/" },
  { label: "Journal", href: "/journal/" }
];

const aesthetics = [
  {
    label: "Neo Deco",
    description: "Glamour. Geometry. Polish. A modern take on timeless design codes.",
    image: "/homepage-generated-assets-hires/aesthetic-neo-deco.png",
    href: "/guides/the-art-of-mixing/"
  },
  {
    label: "Afrohemian",
    description: "Soulful. Textured. Collected. A celebration of craft, culture, and storytelling.",
    image: "/homepage-generated-assets-hires/aesthetic-afrohemian.png",
    href: "/guides/afrohemian-rooms-with-soul/"
  }
];

const guides = [
  {
    title: "Layering Like a Designer",
    description: "Build depth with texture, tone, and timeless pieces.",
    image: "/homepage-generated-assets-hires/guide-layering-like-a-designer.png",
    href: "/guides/layering-like-a-designer/"
  },
  {
    title: "Brass Is Back",
    description: "Warm metals, modern forms, and how to style them right.",
    image: "/homepage-generated-assets-hires/guide-brass-is-back.png",
    href: "/guides/brass-is-back/"
  },
  {
    title: "The Art of Mixing",
    description: "Blend eras, materials, and influences with ease.",
    image: "/homepage-generated-assets-hires/guide-the-art-of-mixing.png",
    href: "/guides/the-art-of-mixing/"
  }
];

const products = [
  {
    title: "Riviera Velvet Chair",
    slug: "vale-velvet-chair",
    image: "/homepage-generated-assets-hires/product-riviera-velvet-chair.png",
    meta: "Ochre Velvet / Brass Base",
    price: "$1,450"
  },
  {
    title: "Safi Marble Side Table",
    slug: "arlo-marble-side-table",
    image: "/homepage-generated-assets-hires/product-safi-marble-side-table.png",
    meta: "Black Marble / Hand-carved",
    price: "$890"
  },
  {
    title: "Zola Ceramic Vessel",
    slug: "riva-ceramic-vessel",
    image: "/homepage-generated-assets-hires/product-zola-ceramic-vessel.png",
    meta: "Terracotta / Hand-thrown",
    price: "$240"
  },
  {
    title: "Oro Wall Sconce",
    slug: "hearth-brass-pendant",
    image: "/homepage-generated-assets-hires/product-oro-wall-sconce.png",
    meta: "Brushed Brass / Opal Glass",
    price: "$320"
  }
];

const trendItems = [
  "Earth Tones, Elevated",
  "Craft as Currency",
  "Curves, Not Corners",
  "Global Influence"
];

const socials = [
  "/homepage-generated-assets-hires/social-follow-01.png",
  "/homepage-generated-assets-hires/social-follow-02.png",
  "/homepage-generated-assets-hires/social-follow-03.png",
  "/homepage-generated-assets-hires/social-follow-04.png"
];

const footerColumns = [
  {
    title: "Shop",
    items: [
      { label: "New In", href: "/shop/" },
      { label: "Furniture", href: "/shop/#furniture" },
      { label: "Lighting", href: "/shop/#lighting" },
      { label: "Decor", href: "/shop/#decor" },
      { label: "Textiles", href: "/shop/#textiles" },
      { label: "The Curated Cart", href: "/shop/" }
    ]
  },
  {
    title: "Guides",
    items: [
      { label: "Styling Guides", href: "/guides/" },
      { label: "Design Principles", href: "/guides/" },
      { label: "Room Ideas", href: "/guides/afrohemian-rooms-with-soul/" },
      { label: "Material Library", href: "/trend-report/#material-forecast" }
    ]
  },
  {
    title: "Company",
    items: [
      { label: "About", href: "/about/" },
      { label: "Affiliate Disclosure", href: "/affiliate-disclosure/" },
      { label: "Journal", href: "/journal/" },
      { label: "Impressum", href: "/impressum/" },
      { label: "Contact", href: "mailto:hello@ochreandchrome.com" }
    ]
  }
];
---

<BaseLayout>
  <main class="page-shell">
    <section class="hero">
      <div class="hero__media">
        <img
          src="/ochre-assets/homepage-hero-brand.png"
          alt="Luxury editorial interior with ochre velvet seating and a brass pendant light."
        />
      </div>
      <div class="hero__overlay"></div>
      <div class="hero__inner">
        <header class="topbar">
          <a href="/" class="brand">
            <span>Ochre</span>
            <span>&amp; Chrome</span>
          </a>
          <nav class="topnav" aria-label="Primary">
            {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
          </nav>
          <div class="topbar__tools" aria-hidden="true">
            <span class="tool tool--search"></span>
            <span class="tool tool--save"></span>
            <span class="tool tool--cart"></span>
          </div>
        </header>

        <div class="hero__content">
          <div class="hero-copy">
            <h1>Design With Depth.</h1>
            <p>
              Curated aesthetics, shoppable guides, and styling rules for the intentional modern
              home.
            </p>
            <div class="hero-actions">
              <a href="/shop/" class="button button--primary">Shop the Edit</a>
              <a href="/guides/" class="button button--ghost">Explore Guides</a>
            </div>
          </div>

          <aside class="lead-card">
            <div class="lead-card__body">
              <h2>Design with intention.</h2>
              <p>
                Receive our free guide with expert principles, timeless ideas, and a curated
                starter checklist.
              </p>
              <div class="lead-form" aria-label="Newsletter signup unavailable">
                <input type="email" value="Newsletter coming soon" aria-label="Newsletter signup unavailable" disabled />
                <button type="button" class="button button--primary button--full" disabled>
                  Coming Soon
                </button>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="section intro-grid">
      <div class="section-heading">
        <span class="eyebrow">Shop by Aesthetic</span>
        <h2>Two worlds. One home.</h2>
      </div>

      <div class="aesthetic-grid">
        {aesthetics.map((item) => (
          <article class="aesthetic-card">
            <img src={item.image} alt={item.label} />
            <div class="aesthetic-card__content">
              <h3>{item.label}</h3>
              <p>{item.description}</p>
              <a href={item.href} class="inline-link">
                Explore {item.label}
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <span class="eyebrow">Latest Styling Guides</span>
        <h2>Ideas to live by.</h2>
      </div>

      <div class="guide-grid">
        {guides.map((guide) => (
          <article class="guide-card">
            <img src={guide.image} alt={guide.title} />
            <div class="guide-card__content">
              <h3>{guide.title}</h3>
              <p>{guide.description}</p>
              <a href={guide.href} class="inline-link">Read Guide</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section curated-cart">
      <div class="section-heading section-heading--tight">
        <span class="eyebrow">The Curated Cart</span>
        <h2>The Curator's Edit.</h2>
        <p>Handpicked pieces to ground your space in beauty and meaning.</p>
      </div>

      <div class="product-grid">
        {products.map((product) => (
          <article class="product-card">
            <div class="product-card__media">
              <img src={product.image} alt={product.title} />
            </div>
            <div class="product-card__content">
              <h3>{product.title}</h3>
              <p>{product.meta}</p>
              <strong>{product.price}</strong>
              <div class="product-card__footer">
                <a href={`/products/${product.slug}/`} class="inline-link">View Details</a>
                <button class="add-button" type="button" aria-label={`Add ${product.title}`}>
                  +
                </button>
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="section-cta">
        <a href="/shop/" class="inline-link inline-link--large">View the Full Curated Cart</a>
      </div>
    </section>

    <section class="section trend-layout">
      <div class="trend-copy">
        <span class="eyebrow">Trend Report</span>
        <h2>What's Next in Design</h2>
        <p>
          Insight, direction, and emerging ideas shaping the spaces we'll live in.
        </p>
        <a href="/trend-report/" class="button button--primary">Read the Latest Report</a>
      </div>

      <div class="trend-feature">
        <img
          src="/homepage-generated-assets-hires/trend-report-whats-next-in-design.png"
          alt="Terracotta dining vignette with paper lanterns, abstract art, and a black vessel."
        />
        <div class="trend-panel">
          <span class="trend-panel__season">Spring / Summer 2026</span>
          <ul>
            {trendItems.map((item) => (
              <li>
                <a href={`/trend-report/#${item.toLowerCase().replaceAll(" ", "-").replaceAll(",", "")}`}>
                  <span>{item}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="section social-section">
      <div class="section-heading section-heading--split">
        <div>
          <span class="eyebrow">Design in Real Life</span>
          <h2>Follow along @ochreandchrome</h2>
        </div>
        <div class="social-notes">
          <span>Curated with Intention</span>
          <span>Crafted to Last</span>
          <span>Global Perspective</span>
        </div>
      </div>

      <div class="social-grid">
        {socials.map((social, index) => (
          <img src={social} alt={`Editorial interior detail ${index + 1}`} />
        ))}
      </div>
    </section>

    <footer class="site-footer">
      <div class="site-footer__main">
        <div class="footer-brand">
          <a href="/" class="brand brand--footer">
            <span>Ochre</span>
            <span>&amp; Chrome</span>
          </a>
          <p>
            Curated aesthetics, shoppable guides, and styling rules for the intentional modern
            home.
          </p>
          <div class="footer-social">
            <a href="https://www.pinterest.com/ochreandchrome/" aria-label="Pinterest">P</a>
            <a href="mailto:hello@ochreandchrome.com?subject=Instagram%20profile" aria-label="Instagram profile pending">I</a>
            <a href="mailto:hello@ochreandchrome.com" aria-label="Email">M</a>
          </div>
        </div>

        <div class="footer-columns">
          {footerColumns.map((column) => (
            <div class="footer-column">
              <h3>{column.title}</h3>
              <ul>
                {column.items.map((item) => (
                  <li><a href={item.href}>{item.label}</a></li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <div class="site-footer__meta">
        <span>&copy; 2026 Ochre &amp; Chrome. All rights reserved.</span>
        <div>
          <a href="/affiliate-disclosure/">Affiliate Disclosure</a>
          <a href="/privacy/">Privacy</a>
          <a href="/terms/">Terms</a>
          <a href="/impressum/">Impressum</a>
        </div>
      </div>
    </footer>
  </main>
</BaseLayout>
