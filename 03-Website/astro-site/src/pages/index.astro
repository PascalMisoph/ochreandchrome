---
import BaseLayout from "../layouts/BaseLayout.astro";
import GuideCard from "../components/GuideCard.astro";
import NewsletterSignup from "../components/NewsletterSignup.astro";
import ProductCard from "../components/ProductCard.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { aesthetics, homepageGuides, homepageProducts, socials, trendItems } from "../data/home";

---

<BaseLayout>
  <main class="page-shell">
    <section class="hero">
      <div class="hero__media">
        <img
          src="/ochre-assets/homepage-hero-brand.png"
          alt="Luxury editorial interior with ochre velvet seating and a brass pendant light."
        />
      </div>
      <div class="hero__overlay"></div>
      <SiteHeader variant="overlay" className="home-nav" />
      <div class="hero__inner">
        <div class="hero__content">
          <div class="hero-copy">
            <h1>Design With Depth.</h1>
            <p>
              Curated aesthetics, shoppable guides, and styling rules for the intentional modern
              home.
            </p>
            <div class="hero-actions">
              <a href="/shop/" class="button button--primary">Shop the Edit</a>
              <a href="/guides/" class="button button--ghost">Explore Guides</a>
            </div>
          </div>

        </div>
      </div>
    </section>

    <section class="section intro-grid">
      <div class="section-heading">
        <span class="eyebrow">Shop by Aesthetic</span>
        <h2>Two worlds. One home.</h2>
      </div>

      <div class="aesthetic-grid">
        {aesthetics.map((item) => (
          <article class="aesthetic-card">
            <img src={item.image} alt={item.label} />
            <div class="aesthetic-card__content">
              <h3>{item.label}</h3>
              <p>{item.description}</p>
              <a href={item.href} class="inline-link">
                Explore {item.label}
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <span class="eyebrow">Latest Styling Guides</span>
        <h2>Ideas to live by.</h2>
      </div>

      <div class="guide-grid">
        {homepageGuides.map((guide) => (
          <GuideCard {...guide} />
        ))}
      </div>
    </section>

    <section class="section curated-cart">
      <div class="section-heading section-heading--tight">
        <span class="eyebrow">The Curated Cart</span>
        <h2>The Curator's Edit.</h2>
        <p>Handpicked pieces to ground your space in beauty and meaning.</p>
      </div>

      <div class="product-grid">
        {homepageProducts.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>

      <div class="section-cta">
        <a href="/shop/" class="inline-link inline-link--large">View the Full Curated Cart</a>
      </div>
    </section>

    <section class="section trend-layout">
      <div class="trend-copy">
        <span class="eyebrow">Trend Report</span>
        <h2>What's Next in Design</h2>
        <p>
          Insight, direction, and emerging ideas shaping the spaces we'll live in.
        </p>
        <a href="/trend-report/" class="button button--primary">Read the Latest Report</a>
      </div>

      <div class="trend-feature">
        <img
          src="/homepage-generated-assets-hires/trend-report-whats-next-in-design.png"
          alt="Terracotta dining vignette with paper lanterns, abstract art, and a black vessel."
        />
        <div class="trend-panel">
          <span class="trend-panel__season">Spring / Summer 2026</span>
          <ul>
            {trendItems.map((item) => (
              <li>
                <a href={`/trend-report/#${item.toLowerCase().replaceAll(" ", "-").replaceAll(",", "")}`}>
                  <span>{item}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="section social-section">
      <div class="section-heading section-heading--split">
        <div>
          <span class="eyebrow">Pinterest</span>
          <h2>Follow @ochreandchrome on Pinterest</h2>
        </div>
        <div class="social-notes">
          <span>Curated with Intention</span>
          <span>Crafted to Last</span>
          <span>Global Perspective</span>
        </div>
      </div>

      <div class="social-grid">
        {socials.map((social, index) => (
          <img src={social} alt={`Editorial interior detail ${index + 1}`} />
        ))}
      </div>

      <aside class="lead-card">
        <div class="lead-card__body">
          <h2>Design with intention.</h2>
          <p>
            Receive our free guide with expert principles, timeless ideas, and a curated
            starter checklist.
          </p>
          <NewsletterSignup buttonClass="button button--primary button--full" />
        </div>
      </aside>
    </section>

  </main>
</BaseLayout>
