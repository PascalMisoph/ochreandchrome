---
const {
  current = "",
  variant = "light",
  className = ""
} = Astro.props;

const navItems = [
  { label: "Shop", href: "/shop/", key: "shop" },
  { label: "Guides", href: "/guides/", key: "guides" },
  { label: "Trend Report", href: "/trend-report/", key: "trend-report" },
  { label: "Journal", href: "/journal/", key: "journal" },
  { label: "About", href: "/about/", key: "about" }
];

const headerClass = ["oc-nav", `oc-nav--${variant}`, className].filter(Boolean).join(" ");
const navId = `primary-nav-${Math.random().toString(36).slice(2)}`;
---

<header class={headerClass}>
  <a href="/" class="oc-brand" data-astro-reload>Ochre <span>&amp;</span> Chrome</a>
  <button class="oc-nav__toggle" type="button" aria-label="Menu" aria-expanded="false" aria-controls={navId}>
    <i></i>
  </button>
  <nav id={navId} aria-label="Primary">
    {navItems.map((item) => (
      <a href={item.href} aria-current={current === item.key ? "page" : undefined}>
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script>
  document.querySelectorAll(".oc-nav__toggle").forEach((toggle) => {
    toggle.addEventListener("click", () => {
      const header = toggle.closest(".oc-nav");
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      header?.classList.toggle("is-open", !expanded);
    });
  });
</script>
