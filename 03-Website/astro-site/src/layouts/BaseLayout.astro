---
import "../styles/global.css";

const {
  title = "Ochre & Chrome | Design With Depth",
  description = "Curated aesthetics, shoppable guides, and styling rules for the intentional modern home."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700&family=Montserrat:wght@500;600&family=Playfair+Display:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="/homepage-generated-assets-hires/ebook-cover.png" />
  </head>
  <body>
    <slot />
  </body>
</html>
